class PalindromeService {

    // 1. Two Pointer Approach (O(1) space)
    public boolean isPalindromeTwoPointer(String input) {
        int left = 0;
        int right = input.length() - 1;

        while (left < right) {
            if (input.charAt(left) != input.charAt(right)) {
                return false;
            }
            left++;
            right--;
        }
        return true;
    }

    // 2. Reverse String Approach
    public boolean isPalindromeReverse(String input) {
        String reversed = new StringBuilder(input).reverse().toString();
        return input.equals(reversed);
    }

    // 3. Stack Approach
    public boolean isPalindromeStack(String input) {
        java.util.Stack<Character> stack = new java.util.Stack<>();

        for (char ch : input.toCharArray()) {
            stack.push(ch);
        }

        for (char ch : input.toCharArray()) {
            if (ch != stack.pop()) {
                return false;
            }
        }
        return true;
    }
}

public class PalindromePerformanceApp {

    public static void main(String[] args) {

        String input = "madamimadam"; // test string

        PalindromeService service = new PalindromeService();

        // -------- Two Pointer --------
        long start1 = System.nanoTime();
        boolean result1 = service.isPalindromeTwoPointer(input);
        long end1 = System.nanoTime();

        // -------- Reverse --------
        long start2 = System.nanoTime();
        boolean result2 = service.isPalindromeReverse(input);
        long end2 = System.nanoTime();

        // -------- Stack --------
        long start3 = System.nanoTime();
        boolean result3 = service.isPalindromeStack(input);
        long end3 = System.nanoTime();

        // -------- Results --------
        System.out.println("Two Pointer Result: " + result1 + 
                " | Time: " + (end1 - start1) + " ns");

        System.out.println("Reverse Method Result: " + result2 + 
                " | Time: " + (end2 - start2) + " ns");

        System.out.println("Stack Method Result: " + result3 + 
                " | Time: " + (end3 - start3) + " ns");
    }
}
